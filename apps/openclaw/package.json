    "pino": "^9.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.30.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
