# 服务端口
PORT=3301

# PostgreSQL 连接地址（omnia_core 数据库）
DATABASE_URL=postgresql://omnia:omnia@localhost:5432/omnia_core

# OpenClaw 网关连接
GATEWAY_URL=ws://localhost:8080
GATEWAY_TOKEN=your-gateway-token

# 控制台 API Key（console 前端访问 /api/* 使用）
API_KEY=dev-api-key

# 业务服务 Service Token（server 访问 /open/* 使用）
SERVICE_TOKEN=dev-service-token

# Agent 定义文件目录（磁盘发现源）
AGENTS_DIR=~/.openclaw/agents

# OpenClaw 配置文件路径（配置发现源）
OPENCLAW_CONFIG=~/.openclaw/openclaw.json

# 日志级别：fatal | error | warn | info | debug | trace
LOG_LEVEL=debug

# CORS 允许的来源（生产环境配置）
CORS_ORIGIN=http://localhost:5301
