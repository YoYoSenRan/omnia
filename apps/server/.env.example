# 服务端口
PORT=3002

# PostgreSQL 连接地址（omnia_app 数据库）
DATABASE_URL=postgresql://omnia:omnia@localhost:5432/omnia_app

# OpenClaw 服务地址
OPENCLAW_URL=http://localhost:3001

# Web 前端 API Key（web 前端访问使用）
API_KEY=dev-app-api-key

# Service Token（与 openclaw 一致，用于调用 /open/* 接口）
SERVICE_TOKEN=dev-service-token

# 日志级别
LOG_LEVEL=debug

# CORS 允许的来源（生产环境配置）
CORS_ORIGIN=http://localhost:5174
